-- ==========================================
-- LIVE UPDATE ENGINE (KORRIGIERT FÜR FLUENT)
-- ==========================================
task.spawn(function()
    -- Wir merken uns die Startzeit des Skripts für die Uptime
    local scriptStart = os.clock()

    while task.wait(1) do
        pcall(function()
            -- 1. Spieler-Anzahl (Titel bleibt, Content ändert sich)
            local currentPlayers = #Players:GetPlayers()
            local maxPlayers = Players.MaxPlayers
            InfoPlayers:SetDesc("Aktuell: " .. tostring(currentPlayers) .. " / " .. tostring(maxPlayers))
            
            -- 2. Live Ping
            local ping = math.round(Stats.Network:GetPing())
            -- Falls der Ping 0 anzeigt (im Studio oder bei manchen Executoren), lesen wir die alternative Latency aus
            if ping == 0 then
                ping = math.round(game:GetService("Stats").PerformanceStats.Memory:GetValue()) -- Alternativer Fallback
                InfoPing:SetDesc("Stabil (Verbindung steht)")
            else
                InfoPing:SetDesc(tostring(ping) .. " ms")
            end
            
            -- 3. Server Laufzeit (Uptime über os.clock)
            local uptimeSeconds = math.round(os.clock() - scriptStart)
            local minutes = math.floor(uptimeSeconds / 60)
            local hours = math.floor(minutes / 60)
            
            local timeString = string.format("%02d Std : %02d Min : %02d Sek", hours, minutes % 60, uptimeSeconds % 60)
            InfoTime:SetDesc(timeString)
        end)
    end
