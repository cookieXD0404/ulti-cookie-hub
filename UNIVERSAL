local camera = workspace.CurrentCamera
local lPlayer = game.Players.LocalPlayer

-- Modernes, stabiles Raycasting für den Wall Check
local function isVisible(part, character)
    if not aimWallCheck then return true end
    
    local origin = camera.CFrame.Position
    local direction = part.Position - origin
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    -- Wir ignorieren dich selbst, das gegnerische Modell und Zubehör/Hüte
    raycastParams.FilterDescendantsInstances = {lPlayer.Character, character, camera}
    raycastParams.IgnoreWater = true
    
    local result = workspace:Raycast(origin, direction, raycastParams)
    
    -- Wenn der Strahl nichts trifft, ist der Weg frei. 
    -- Wenn er was trifft, prüfen wir, ob es eine Wand (CanCollide = true) ist.
    if result then
        if result.Instance.CanCollide == false then
            return true -- Ignoriere transparente/durchlässige Deko-Wände
        end
        return false -- Feste Wand blockiert die Sicht
    end
    
    return true
end

local function getTargetPart(character)
    if currentTargetPart == "Kopf" then
        return character:FindFirstChild("Head") or character:FindFirstChild("UpperTorso")
    elseif currentTargetPart == "Körper" then
        return character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
    elseif currentTargetPart == "Modell-Mitte" then
        return character:FindFirstChildOfClass("BasePart")
    end
    return nil
end

local function getClosestPlayer()
    local closestTarget = nil
    local shortestDistance = fovCircleRadius
    local targets = {}
    
    if customFolderTargeting then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") and obj ~= lPlayer.Character then
                table.insert(targets, obj)
            end
        end
    else
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= lPlayer and p.Character then
                if not (aimTeamCheck and p.Team == lPlayer.Team) then
                    table.insert(targets, p.Character)
                end
            end
        end
    end
    
    for _, char in pairs(targets) do
        local part = getTargetPart(char)
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        
        local isAlive = true
        if humanoid and humanoid.Health <= 0 then isAlive = false end
        
        if part and (not aimDeadCheck or isAlive) then
            -- Erst auf dem Bildschirm prüfen, um Performance bei Raycasts zu sparen
            local pos, onScreen = camera:WorldToViewportPoint(part.Position)
            
            if onScreen then
                local mousePos = game:GetService("UserInputService"):GetMouseLocation()
                local distance = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                
                if distance < shortestDistance then
                    -- Nur wenn er im FOV ist, werfen wir den präzisen Wall-Check an
                    if isVisible(part, char) then
                        shortestDistance = distance
                        closestTarget = char
                    end
                end
            end
        end
    end
    
    return closestTarget
end

game:GetService("RunService").RenderStepped:Connect(function()
    if hasDrawing and fovCircleEnabled and FOVCircle then
        FOVCircle.Position = game:GetService("UserInputService"):GetMouseLocation()
    end
    
    if not aimbotEnabled then return end
    
    local targetChar = getClosestPlayer()
    if targetChar then
        local targetPart = getTargetPart(targetChar)
        if targetPart then
            local targetPosition = targetPart.Position
            
            if currentTargetPart == "Modell-Mitte" then
                local cframe, _ = targetChar:GetBoundingBox()
                targetPosition = cframe.Position
            end
            
            if predictionEnabled then
                local velocityPart = targetChar:FindFirstChild("HumanoidRootPart") or targetPart
                if velocityPart and velocityPart:IsA("BasePart") then
                    targetPosition = targetPosition + (velocityPart.AssemblyLinearVelocity * (predictionStrength / 10))
                end
            end
            
            -- WEICHHEIT/SMOOTHNESS BERECHNEN
            local alpha = 1 - math.clamp(aimSmoothness, 0, 0.98)
            
            if currentAimMode == "Camera (Memory)" then
                local currentCFrame = camera.CFrame
                local targetCFrame = CFrame.new(currentCFrame.Position, targetPosition)
                camera.CFrame = currentCFrame:Lerp(targetCFrame, alpha)
                
            elseif currentAimMode == "Mouse (Imitate)" then
                local screenPos, onScreen = camera:WorldToViewportPoint(targetPosition)
                if onScreen then
                    -- GetMouseLocation berücksichtigt das GUI-Offset (Topbar)
                    local mousePos = game:GetService("UserInputService"):GetMouseLocation()
                    
                    -- Berechne die Distanz, die die Maus zurücklegen muss
                    local targetX = (screenPos.X - mousePos.X)
                    local targetY = (screenPos.Y - mousePos.Y)
                    
                    if mousemoverel then
                        -- Falls vorhanden, nutzen wir relative Mausbewegung (pixelgenau)
                        mousemoverel(targetX * alpha, targetY * alpha)
                    else
                        -- Prallfester, absoluter VirtualUser Fix:
                        -- Wandelt das UI-Koordinatensystem exakt in globale Bildschirm-Pixel um
                        local finalX = mousePos.X + (targetX * alpha)
                        local finalY = mousePos.Y + (targetY * alpha)
                        
                        local vu = game:GetService("VirtualUser")
                        vu:CaptureController()
                        -- Injektion direkt auf die berechnete 2D-Fläche
                        vu:MoveMouseToVector2(Vector2.new(finalX, finalY))
                    end
                end
            end
        end
    end
end)

