-- Funktion, um die aktuelle Spielerliste für das Dropdown zu holen
function getPlayerNames()
    local names = {}
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= player then
            table.insert(names, p.Name)
        end
    end
    -- Falls der Server leer ist, leeren Eintrag zeigen, damit Fluent nicht abstürzt
    if #names == 0 then table.insert(names, "Keine anderen Spieler") end
    return names
end

