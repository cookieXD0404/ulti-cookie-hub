-- Der echte IY-Loop
task.spawn(function()
    local lp = game:GetService("Players").LocalPlayer
    local runService = game:GetService("RunService")
    
    runService.Heartbeat:Connect(function()
        if Fluent.Options.IYFlingToggle and Fluent.Options.IYFlingToggle.Value then
            local char = lp.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")
            
            if root and humanoid then
                local power = Fluent.Options.IYFlingSpeed and Fluent.Options.IYFlingSpeed.Value or 100
                
                -- 1. Zwinge den Charakter in den Sitzen-Modus (verhindert Ragdoll/Stürzen)
                humanoid.Sit = true
                
                -- 2. Kollisionen der Gliedmaßen ausschalten, damit sie nicht clippen
                for _, part in pairs(char:GetChildren()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
                
                -- 3. Der echte IY-Rotations-Angriff:
                -- Die X-Achse bekommt die volle Wucht ab, wodurch die Hitbox flach rotiert
                root.AssemblyAngularVelocity = Vector3.new(power * 100, 0, 0)
                
                -- Erlaubt dir, dich normal zu bewegen, erzeugt aber genug physikalischen Druck
                root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            end
        end
    end)
end)











