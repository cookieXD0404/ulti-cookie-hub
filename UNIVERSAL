-- Loop für die verschiedenen Erkennungsmethoden
game:GetService("RunService").Heartbeat:Connect(function()
    if not antiFallEnabled then return end
    
    local player = game.Players.LocalPlayer
    local character = player.Character
    if not character then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not (humanoid and rootPart) or humanoid.Health <= 0 then return end

    -- MODUS 1: No State Reset (Standard für viele Spiele)
    -- Verhindert, dass der Charakter den "Landed" (Gelandet) Status triggert, 
    -- an dem viele Spiele ihren Schaden festmachen.
    if currentFallMode == "No State Reset" then
        if humanoid:GetState() == Enum.HumanoidStateType.Freefall then
            -- Sobald wir fallen, zwingen wir den Humanoid in den Running-State, 
            -- bevor das Spiel merkt, dass wir aufgekommen sind.
            humanoid:ChangeState(Enum.HumanoidStateType.Running)
        end

    -- MODUS 2: Velocity Break (Für Spiele, die die Aufprallgeschwindigkeit messen)
    -- Wenn du extrem schnell fällst, bremst das Skript dich kurz vor dem Boden sanft ab.
    elseif currentFallMode == "Velocity Break" then
        if rootPart.AssemblyLinearVelocity.Y < -40 then -- Wenn du schnell fällst
            local raycastParams = RaycastParams.new()
            raycastParams.FilterDescendantsInstances = {character}
            raycastParams.FilterType = Enum.RaycastFilterType.Exclude
            
            -- Prüfen, ob der Boden kurz bevorsteht (10 Studs unter dir)
            local raycastResult = workspace:Raycast(rootPart.Position, Vector3.new(0, -10, 0), raycastParams)
            
            if raycastResult then
                -- Fallgeschwindigkeit kurz vor dem Aufprall auf fast 0 setzen
                rootPart.AssemblyLinearVelocity = Vector3.new(
                    rootPart.AssemblyLinearVelocity.X,
                    -2, -- Sanftes Aufkommen
                    rootPart.AssemblyLinearVelocity.Z
                )
            end
        end

    -- MODUS 3: Freefall Spoof (Für Spiele mit serverseitiger Abfrage)
    -- Deaktiviert den Freefall-Status komplett, sodass das Spiel denkt, du läufst permanent.
    elseif currentFallMode == "Freefall Spoof" then
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)
    end
end)

