-- ==========================================
-- ANTI-AFK CORE ENGINE
-- ==========================================

-- Methode 1: Der offizielle Roblox Core-Bypass (Fängt die IDLE-Kick-Meldung direkt ab)
-- Das läuft permanent im Hintergrund, sobald der Script geladen ist, als extra Schutzschicht.
pcall(function()
    lPlayer.Idled:Connect(function()
        if antiAfkEnabled then
            VirtualUser:Button2Down(Vector2.new(0,0), camera.CFrame)
            task.wait(1)
            VirtualUser:Button2Up(Vector2.new(0,0), camera.CFrame)
        end
    end)
end)

-- Methode 2: Live-Loop für die ausgewählten Charakter-Modi
RunService.Heartbeat:Connect(function(deltaTime)
    if not antiAfkEnabled then return end
    
    afkTimer = afkTimer + deltaTime
    
    -- Führt alle 15 Sekunden eine Aktion aus, um den Server-Timeout zu resetten
    if afkTimer >= 15 then
        afkTimer = 0
        
        local character = lPlayer.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        
        if antiAfkMode == "Virtual Input" then
            -- Simuliert eine unschädliche Mausbewegung im Roblox-Fenster
            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new(1, 1))
            end)
            
        elseif antiAfkMode == "Jump Physics" and humanoid then
            -- Lässt den Charakter kurz springen, falls er am Boden steht
            pcall(function()
                if humanoid.FloorMaterial ~= Enum.Material.Air then
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end)
        end
    end
end)

