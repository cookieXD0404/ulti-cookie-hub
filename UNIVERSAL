local function isEnemy(targetPlayer)
    if not teamCheck then return true end
    return targetPlayer.Team ~= player.Team
end

-- Prüft, ob eine Wand zwischen deiner Kamera und dem Gegner ist
local function isVisible(targetPart)
    if not wallCheck then return true end
    local castRay = Ray.new(camera.CFrame.Position, (targetPart.Position - camera.CFrame.Position).Unit * 1000)
    local hit, position = workspace:FindPartOnRayWithIgnoreList(castRay, {player.Character, targetPart.Parent})
    return hit == nil
end

-- Sucht den besten Gegner im FOV-Kreis
local function getClosestPlayerToMouse()
    local closestPlayer = nil
    local shortestDistance = fovCircleEnabled and fovRadius or math.huge

    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild(aimPart) and v.Character:FindFirstChildOfClass("Humanoid") then
            if v.Character.Humanoid.Health > 0 and isEnemy(v) and isVisible(v.Character[aimPart]) then
                local pos, onScreen = camera:WorldToViewportPoint(v.Character[aimPart].Position)
                if onScreen then
                    local mousePos = Vector2.new(mouse.X, mouse.Y)
                    local distance = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    
                    if distance < shortestDistance then
                        shortestDistance = distance
                        closestPlayer = v
                    end
                end
            end
        end
    end
    return closestPlayer
end

-- AIMBOT & FOV LOOP
runService.RenderStepped:Connect(function()
    -- FOV Kreis an der Maus positionieren und updaten
    if fovCircleEnabled then
        fovCircle.Position = Vector2.new(mouse.X, mouse.Y + 36) -- +36 gleicht den Roblox-Top-Bar-Offset aus
        fovCircle.Radius = fovRadius
        fovCircle.Visible = true
    else
        fovCircle.Visible = false
    end

    -- Aimbot Logik
    if aimbotEnabled then
        -- Prüfen, ob "Only Lock Shot" aktiv ist und ob geschossen (Klick gehalten) wird
        if onlyLockShot and not uis:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
            return
        end

        local target = getClosestPlayerToMouse()
        if target and target.Character and target.Character:FindFirstChild(aimPart) then
            local targetPosition = target.Character[aimPart].Position
            
            -- PREDICTION: Berechnet die Bewegung basierend auf der Geschwindigkeit des Gegners
            if predictionEnabled and target.Character:FindFirstChild("HumanoidRootPart") then
                local velocity = target.Character.HumanoidRootPart.AssemblyLinearVelocity
                -- Eine einfache Zeit-Konstante (0.135) simuliert die Flugzeit/Ping
                targetPosition = targetPosition + (velocity * 0.135)
            end

            -- SMOOTHING (Interpolation / Glättung)
            local targetCFrame = CFrame.new(camera.CFrame.Position, targetPosition)
            camera.CFrame = camera.CFrame:Lerp(targetCFrame, 1 / smoothingValue)
        end
    end
end)

