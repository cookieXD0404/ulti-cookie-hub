-- 5. DER JUMP LOOP (Hintergrund-Überwachung)
game:GetService("RunService").Heartbeat:Connect(function()
    local player = game.Players.LocalPlayer
    local character = player.Character
    if not character then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not (humanoid and rootPart) or humanoid.Health <= 0 then return end

    -- Erkennt, ob die Leertaste gedrückt wird / der Spieler springt
    local isJumping = game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.Space)

    -- Modus 1: JumpPower Loop (Erzwingen)
    if currentJumpMode == "JumpPower" and antiJumpResetEnabled then
        if humanoid.JumpPower ~= jumpValue then
            humanoid.JumpPower = jumpValue
        end

    -- Modus 2: JumpHeight Loop (Erzwingen)
    elseif currentJumpMode == "JumpHeight" and antiJumpResetEnabled then
        if humanoid.JumpHeight ~= jumpValue then
            humanoid.JumpHeight = jumpValue
        end

    -- Modus 3: Velocity Jump (Gibt einen physikalischen Impuls nach oben beim Abspringen)
    elseif currentJumpMode == "Velocity" then
        -- Wenn der Spieler springt und sich am Boden befindet
        if isJumping and rootPart.AssemblyLinearVelocity.Y < 1 then
            rootPart.AssemblyLinearVelocity = Vector3.new(
                rootPart.AssemblyLinearVelocity.X,
                jumpValue, -- Schießt den Spieler nach oben
                rootPart.AssemblyLinearVelocity.Z
            )
        end

    -- Modus 4: CFrame Jump (Teleportiert dich beim Drücken der Leertaste ruckartig nach oben)
    elseif currentJumpMode == "CFrame" then
        if isJumping and rootPart.AssemblyLinearVelocity.Y < 1 then
            -- Setzt die Position direkt ein paar Studs höher
            rootPart.CFrame = rootPart.CFrame * CFrame.new(0, jumpValue / 5, 0)
        end
    end
end)

