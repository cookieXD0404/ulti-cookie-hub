            local targetPlayer = game.Players:GetPlayerFromCharacter(character)
            if targetPlayer and targetPlayer ~= player and isEnemy(targetPlayer) then
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                if humanoid and humanoid.Health > 0 and isVisible(hitPart) then
                    mouse1press()
                    task.wait(0.03)
                    mouse1release()
                end
            end
        end
    end
end)

