-- Holt das beste Ziel im Silent-Aim-Radius
local function getSilentTarget()
    local closestPlayer = nil
    local shortestDistance = silentFovEnabled and silentFovRadius or math.huge

    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild(silentAimPart) and v.Character:FindFirstChildOfClass("Humanoid") then
            if v.Character.Humanoid.Health > 0 and isSilentEnemy(v) and isSilentVisible(v.Character[silentAimPart]) then
