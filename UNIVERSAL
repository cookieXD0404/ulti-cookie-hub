-- LIGHTING BACKEND (Speichert die Originalwerte)
-- ==========================================
local lightBackup = {
    Brightness = game:GetService("Lighting").Brightness,
    Ambient = game:GetService("Lighting").Ambient,
    OutdoorAmbient = game:GetService("Lighting").OutdoorAmbient
}

-- Zentrale Update-Funktion für die Helligkeit
local function updateFullbright()
    local lighting = game:GetService("Lighting")
    
    -- Wenn der Toggle AN ist, berechnen wir die Werte basierend auf dem Slider
    if Fluent.Options.FBToggle and Fluent.Options.FBToggle.Value then
        local sliderVal = Fluent.Options.FBSlider and Fluent.Options.FBSlider.Value or 5
        
        -- Skalierung von 0 (dunkel) bis 10 (extrem hell)
        lighting.Brightness = sliderVal * 0.5
        
        -- Umgebungslicht anpassen (0 = Schwarz, 10 = Weiß/Fullbright)
        local rgbVal = (sliderVal / 10) * 255
        lighting.Ambient = Color3.fromRGB(rgbVal, rgbVal, rgbVal)
        lighting.OutdoorAmbient = Color3.fromRGB(rgbVal, rgbVal, rgbVal)
    else
        -- Wenn der Toggle AUS ist, laden wir die Originalwerte der Map
        lighting.Brightness = lightBackup.Brightness
        lighting.Ambient = lightBackup.Ambient
        lighting.OutdoorAmbient = lightBackup.OutdoorAmbient
    end
end

