-- Speichert die Originalwerte der Objekte vor der Optimierung
local perfBackup = {}

-- Hilfsfunktion, um zu prüfen, ob eine Option im Multi-Dropdown gewählt ist
local function isOptionSelected(optionName)
    if Fluent.Options.PerfDropdown and Fluent.Options.PerfDropdown.Value then
        return Fluent.Options.PerfDropdown.Value[optionName] == true
    end
    return false
end

