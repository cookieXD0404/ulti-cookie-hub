-- ==========================================
-- METAMETHOD HOOKS (Das eigentliche Silent Aim)
-- ==========================================

-- Hook 1: Für ältere/klassische Waffensysteme (mouse.Hit / mouse.Target)
local oldIndex
oldIndex = hookmetamethod(game, "__index", function(self, index)
    if silentAimEnabled and self == mouse and (index == "Hit" or index == "Target") and not checkcaller() then
        if math.random(1, 100) <= silentHitChance then
            local target = getSilentTarget()
            if target and target.Character and target.Character:FindFirstChild(silentAimPart) then
                if index == "Hit" then
                    return target.Character[silentAimPart].CFrame
                elseif index == "Target" then
                    return target.Character[silentAimPart]
                end
            end
        end
    end
    return oldIndex(self, index)
end)

-- Hook 2: Für moderne Waffensysteme (workspace:Raycast)
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if silentAimEnabled and self == workspace and method == "Raycast" and not checkcaller() then
        if math.random(1, 100) <= silentHitChance then
            local target = getSilentTarget()
            if target and target.Character and target.Character:FindFirstChild(silentAimPart) then
                local origin = args[1]
                local targetPos = target.Character[silentAimPart].Position
                args[2] = (targetPos - origin).Unit * 1000 -- Richtungsvektor biegen
            end
        end
    end
    return oldNamecall(self, unpack(args))
end)

