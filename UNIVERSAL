-- Variables
local perfBoostEnabled = false
local selectedOptions = {}

-- Speicher für originale Zustände, um alles perfekt rückgängig zu machen
local terrain = workspace:FindFirstChildOfClass("Terrain")
local Lighting = game:GetService("Lighting")

local originalStates = {
    Materials = {},
    Reflectance = {},
    GlobalShadows = Lighting.GlobalShadows,
    WaterWaveSize = terrain and terrain.WaterWaveSize or 0.1,
    WaterWaveSpeed = terrain and terrain.WaterWaveSpeed or 10,
    WaterTransparency = terrain and terrain.WaterTransparency or 1
}

-- Hilfsfunktion: Optimiert ein einzelnes Objekt basierend auf den Optionen
local function optimizeObject(obj)
    if not perfBoostEnabled then return end
    
    pcall(function()
        -- 1. Texturen & Decals
        if selectedOptions["Textures & Decals"] and (obj:IsA("Texture") or obj:IsA("Decal")) then
            obj.Transparency = 1
        
        -- 2. Materialien zu Smooth Plastic
        elseif selectedOptions["Smooth Materials"] and (obj:IsA("Part") or obj:IsA("MeshPart") or obj:IsA("CornerWedgePart") or obj:IsA("TrussPart")) then
            if not originalStates.Materials[obj] then
                originalStates.Materials[obj] = obj.Material
            end
            obj.Material = Enum.Material.SmoothPlastic
            
        -- 3. Spiegelungen & Glanz entfernen
        elseif selectedOptions["Remove Reflections"] and obj:IsA("BasePart") then
            if not originalStates.Reflectance[obj] then
                originalStates.Reflectance[obj] = obj.Reflectance
            end
            obj.Reflectance = 0
            
        -- 4. Partikel-Effekte unsichtbar machen
        elseif selectedOptions["Disable Particles"] and (obj:IsA("ParticleEmitter") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles")) then
            obj.Enabled = false
            
        -- 5. Lichter / Schattenwurf deaktivieren
        elseif selectedOptions["Disable In-Game Lights"] and (obj:IsA("PointLight") or obj:IsA("SpotLight") or obj:IsA("SurfaceLight")) then
            obj.Enabled = false
        end
    end)
end

-- Funktion zum kompletten Zurücksetzen aller Änderungen
local function resetPerformance()
    pcall(function()
        -- Materialien wiederherstellen
        for obj, mat in pairs(originalStates.Materials) do
            if obj and obj.Parent then obj.Material = mat end
        end
        table.clear(originalStates.Materials)
        
        -- Spiegelungen wiederherstellen
        for obj, ref in pairs(originalStates.Reflectance) do
            if obj and obj.Parent then obj.Reflectance = ref end
        end
        table.clear(originalStates.Reflectance)
        
        -- Texturen, Partikel, Lichter wieder einschalten
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Texture") or obj:IsA("Decal") then
                obj.Transparency = 0
            elseif obj:IsA("ParticleEmitter") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") then
                obj.Enabled = true
            elseif obj:IsA("PointLight") or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
                obj.Enabled = true
            end
        end
        
        -- Schatten und Wasser zurücksetzen
        Lighting.GlobalShadows = originalStates.GlobalShadows
        if terrain then
            terrain.WaterWaveSize = originalStates.WaterWaveSize
            terrain.WaterWaveSpeed = originalStates.WaterWaveSpeed
            terrain.WaterTransparency = originalStates.WaterTransparency
        end
    end)
end

-- Wendet die Optimierung auf die gesamte Welt an
local function applyPerformanceBoost()
    if not perfBoostEnabled then return end
    
    pcall(function()
        -- Globale Schatten ausschalten (massiver FPS Boost!)
        if selectedOptions["Disable Shadows"] then
            Lighting.GlobalShadows = false
        end
        
        -- Wasser-Physik einfrieren
        if terrain and selectedOptions["Low Water Quality"] then
            terrain.WaterWaveSize = 0
            terrain.WaterWaveSpeed = 0
            terrain.WaterTransparency = 0
        end
        
        -- Alle bestehenden Objekte scannen
        for _, obj in pairs(workspace:GetDescendants()) do
            optimizeObject(obj)
        end
    end)
end

-- ==========================================
-- UI INTERFACE (Fluent Multi-Dropdown)
-- ==========================================
MeinMiscTab:AddSection("Performance Booster")

local PerfDropdown = MeinMiscTab:AddDropdown("PerformanceMultiSelect", {
    Title = "Optimierungs-Optionen",
    Description = "Wähle aus, was deaktiviert werden soll.",
    Values = {
        "Textures & Decals", 
        "Smooth Materials", 
        "Remove Reflections", 
        "Disable Particles", 
        "Disable In-Game Lights",
        "Disable Shadows",
        "Low Water Quality"
    },
    Multi = true,
    Default = {},
    Callback = function(Value)
        selectedOptions = Value
        if perfBoostEnabled then
            applyPerformanceBoost()
        end
    end
