runService.Stepped:Connect(function()
    local player = game.Players.LocalPlayer
    local character = player.Character
    if not character then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChild("Humanoid")
    if not rootPart or not humanoid or humanoid.Health <= 0 then return end
    
    -- WENN NOCLIP AKTIV IST:
    if noclipEnabled then
        if currentNoclipMode == "Experimental TP" then
            local moveDir = getMoveDirection()
            
            if moveDir.Magnitude > 0 then
                local raycastParams = RaycastParams.new()
                raycastParams.FilterDescendantsInstances = {character}
                raycastParams.FilterType = Enum.RaycastFilterType.Exclude
                
                local rayOrigin = rootPart.Position
                local rayDirection = moveDir * 3
                local raycastResult = workspace:Raycast(rayOrigin, rayDirection, raycastParams)
                
                if raycastResult and raycastResult.Instance then
                    local hitPart = raycastResult.Instance
                    local hitNormal = raycastResult.Normal
                    local isWall = math.abs(hitNormal.Y) < 0.7
                    
                    if isWall and hitPart.CanCollide then
                        rootPart.Anchored = true
                        rootPart.CFrame = rootPart.CFrame + (moveDir * 1.5)
                        return
                    end
                end
            end
            rootPart.Anchored = false
            
        elseif currentNoclipMode == "Classic Loop" then
            rootPart.Anchored = false
            for _, part in pairs(character:GetChildren()) do
                if part:IsA("BasePart") and part.CanCollide then
                    part.CanCollide = false
                end
            end
            
        elseif currentNoclipMode == "Velocity Phase" then
            rootPart.Anchored = false
            local moveDir = getMoveDirection()
            
            for _, part in pairs(character:GetChildren()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
            
            if moveDir.Magnitude > 0 then
                rootPart.AssemblyLinearVelocity = Vector3.new(
                    moveDir.X * (humanoid.WalkSpeed * 1.5),
                    rootPart.AssemblyLinearVelocity.Y, 
                    moveDir.Z * (humanoid.WalkSpeed * 1.5)
                )
            end
        end
        
    -- WENN NOCLIP AUS IST (Sicherheits-Loop fürs Zurücksetzen):
    else
        -- Stellt sicher, dass Roblox die Kollision nicht im nächsten Frame wieder deaktiviert
        for _, part in pairs(character:GetChildren()) do
            if part:IsA("BasePart") and not part.CanCollide then
                -- HumanoidRootPart sollte im normalen Zustand standardmäßig CanCollide = false haben,
                -- alle anderen Körperteile (Torso, Beine, Arme) müssen true sein.
                if part.Name ~= "HumanoidRootPart" then
                    part.CanCollide = true
                end
            end
        end
    end
end)

