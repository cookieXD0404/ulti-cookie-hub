-- 2. Schutz: Event-basiertes Blocken (falls das Spiel die Werte hart zurücksetzt)
Lighting.Changed:Connect(function(property)
    if fullbrightEnabled then
        -- Wenn das Spiel versucht, Werte zu ändern während Fullbright AN ist -> Direkt wieder überschreiben
        enforceFullbright()
    else
        -- Wenn Fullbright AUS ist, speichern wir normale Map-Wechsel/Tageszeiten ab
        pcall(function()
            if originalLighting[property] ~= nil then
                originalLighting[property] = Lighting[property]
            end
        end)
    end
end)

