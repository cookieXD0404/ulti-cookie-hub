-- Funktion zur Berechnung der Flugrichtung basierend auf gedrückten Tasten
local function getFlyDirection()
    local dir = Vector3.zero
    if uis:IsKeyDown(Enum.KeyCode.W) then dir = dir + camera.CFrame.LookVector end
    if uis:IsKeyDown(Enum.KeyCode.S) then dir = dir - camera.CFrame.LookVector end
    if uis:IsKeyDown(Enum.KeyCode.D) then dir = dir + camera.CFrame.RightVector end
    if uis:IsKeyDown(Enum.KeyCode.A) then dir = dir - camera.CFrame.RightVector end
    if uis:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
    if uis:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.new(0, 1, 0) end
    return dir
end

-- 4. DER FLY LOOP (Jeden Frame ausführen)
runService.Heartbeat:Connect(function(deltaTime)
    if not flying then return end
    
    local player = game.Players.LocalPlayer
    local character = player.Character
    if not character then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChild("Humanoid")
    if not rootPart or not humanoid or humanoid.Health <= 0 then return end
    
    -- Richtung holen
    local flyDir = getFlyDirection()
    
    -- Infinite Yield Style: Charakter schaut IMMER exakt dorthin, wo die Kamera hinschaut
    local camLook = camera.CFrame.LookVector
    local targetRotation = CFrame.lookAt(rootPart.Position, rootPart.Position + Vector3.new(camLook.X, 0, camLook.Z))
    
    -------------------------------------------
    -- MODUS 1: CFrame (Standard Infinite Yield)
    -------------------------------------------
    if currentFlyMode == "CFrame" then
        rootPart.Anchored = false
        rootPart.AssemblyLinearVelocity = Vector3.zero -- Schwerkraft ausschalten
        
        if flyDir.Magnitude > 0 then
            rootPart.CFrame = CFrame.new(rootPart.Position + (flyDir.Unit * flySpeed * deltaTime)) * targetRotation.Rotation
        else
            rootPart.CFrame = CFrame.new(rootPart.Position) * targetRotation.Rotation
        end
        
    -------------------------------------------
    -- MODUS 2: Anchored CFrame (Einfrieren)
    -------------------------------------------
    elseif currentFlyMode == "Anchored CFrame" then
        rootPart.Anchored = true -- Komplett im Raum fixieren (unantastbar für Physik)
        
        if flyDir.Magnitude > 0 then
            rootPart.CFrame = CFrame.new(rootPart.Position + (flyDir.Unit * flySpeed * deltaTime)) * targetRotation.Rotation
        else
            rootPart.CFrame = CFrame.new(rootPart.Position) * targetRotation.Rotation
        end

    -------------------------------------------
    -- MODUS 3: Velocity (Flüssige Physik)
    -------------------------------------------
    elseif currentFlyMode == "Velocity" then
        rootPart.Anchored = false
        
        if flyDir.Magnitude > 0 then
            rootPart.AssemblyLinearVelocity = flyDir.Unit * flySpeed
        else
            rootPart.AssemblyLinearVelocity = Vector3.zero -- Schwebend stoppen
        end
        -- Drehung trotzdem via CFrame erzwingen
        rootPart.CFrame = CFrame.new(rootPart.Position) * targetRotation.Rotation

    -------------------------------------------
    -- MODUS 4: Teleport (Große Sprünge)
    -------------------------------------------
    elseif currentFlyMode == "Teleport" then
        rootPart.Anchored = false
        rootPart.AssemblyLinearVelocity = Vector3.zero
        
        if flyDir.Magnitude > 0 then
            -- Versetzt dich schubweise vorwärts (bricht manche Prediction-Anti-Cheats)
            rootPart.CFrame = CFrame.new(rootPart.Position + (flyDir.Unit * (flySpeed / 10))) * targetRotation.Rotation
        else
            rootPart.CFrame = CFrame.new(rootPart.Position) * targetRotation.Rotation
        end
    end
end)

