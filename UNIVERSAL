-- Funktion zum Aktualisieren der 3D-Anzeige (ESP)
local function updateWaypointESP()
    espFolder:ClearAllChildren()
    if not showWaypointsESP then return end

    for name, pos in pairs(waypoints) do
        local part = Instance.new("Part")
        part.Size = Vector3.new(1, 1, 1)
        part.Position = pos
        part.Anchored = true
        part.CanCollide = false
        part.Transparency = 1
        part.Parent = espFolder

        local bGui = Instance.new("BillboardGui")
        bGui.Size = UDim2.new(0, 200, 0, 50)
        bGui.AlwaysOnTop = true
        bGui.Adornee = part
        bGui.Parent = part

        local textLabel = Instance.new("TextLabel")
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.Text = "[" .. name .. "]"
        textLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
        textLabel.TextSize = 14
        textLabel.Font = Enum.Font.SourceSansBold
        textLabel.Parent = bGui
    end
end

-- Funktion zum Aktualisieren der Custom Listen-GUI
local function refreshCustomGui()
    if not customGuiEnabled or not screenGui then return end
    
    local frame = screenGui:FindFirstChild("MainFrame")
    if not frame then return end
    
    local scroll = frame:FindFirstChild("ScrollList")
    scroll:ClearAllChildren()
    
    -- UI List Layout für saubere Untereinander-Anordnung
    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 5)
    layout.Parent = scroll

    local yOffset = 0
    for name, pos in pairs(waypoints) do
        local item = Instance.new("Frame")
        item.Size = UDim2.new(1, 0, 0, 30)
        item.BackgroundTransparency = 0.8
        item.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        item.Parent = scroll

        -- Name des Wegpunkts
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(0.4, 0, 1, 0)
        lbl.Text = name
        lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
        lbl.TextXAlignment = Enum.TextXAlignment.Left
