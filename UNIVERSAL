Tabs.Misc:AddSection("Performance Optimizer")

-- Multi-Dropdown für die Auswahl der Optimierungen
Tabs.Misc:AddDropdown("PerfDropdown", {
    Title = "Optimization Targets",
    Description = "Wähle aus, was optimiert werden soll",
    Values = {"Shadows", "Textures & Materials", "Decals & Effects"},
    Multi = true,
    Default = {}
})

-- Der Haupt-Toggle für Performance
Tabs.Misc:AddToggle("PerfToggle", {
    Title = "Enable Performance Mode",
    Description = "Optimiert das Spiel basierend auf der Auswahl oben",
    Default = false,
    Callback = function(Value)
        if Value then
            -- ==========================================
            -- OPTIMIERUNG EINSCHALTEN (Backup erstellen & ändern)
            -- ==========================================
            
            -- 1. Schatten optimieren
            if isOptionSelected("Shadows") then
                perfBackup.GlobalShadows = game:GetService("Lighting").GlobalShadows
                game:GetService("Lighting").GlobalShadows = false
            end
            
            -- 2. Texturen, Materialien und Effekte durchgehen
            for _, obj in pairs(workspace:GetDescendants()) do
                -- Texturen & Materialien
                if isOptionSelected("Textures & Materials") then
                    if obj:IsA("BasePart") and not obj:IsA("MeshPart") then
                        perfBackup[obj] = perfBackup[obj] or {Material = obj.Material, CastShadow = obj.CastShadow}
                        obj.Material = Enum.Material.SmoothPlastic
                        obj.CastShadow = false
                    end
                end
                
                -- Decals & Partikel-Effekte
                if isOptionSelected("Decals & Effects") then
                    if obj:IsA("Decal") or obj:IsA("Texture") or obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") or obj:IsA("Fire") then
                        perfBackup[obj] = perfBackup[obj] or {Enabled = obj.Enabled, Visible = (obj:IsA("Decal") or obj:IsA("Texture")) and obj.Transparency or nil}
                        if obj:IsA("Decal") or obj:IsA("Texture") then
                            obj.Transparency = 1
                        else
                            obj.Enabled = false
                        end
                    end
                end
            end
        else
            -- ==========================================
            -- OPTIMIERUNG AUSSCHALTEN (Werte wiederherstellen)
            -- ==========================================
            
            -- Lighting Schatten wiederherstellen
            if perfBackup.GlobalShadows ~= nil then
                game:GetService("Lighting").GlobalShadows = perfBackup.GlobalShadows
            end
            
            -- Alle gespeicherten Objekte zurücksetzen
            for obj, data in pairs(perfBackup) do
                if typeof(obj) == "Instance" and obj.Parent then
                    if data.Material then obj.Material = data.Material end
                    if data.CastShadow ~= nil then obj.CastShadow = data.CastShadow end
                    if data.Enabled ~= nil then obj.Enabled = data.Enabled end
                    if data.Transparency then obj.Transparency = data.Transparency end
                end
            end
            
            -- Backup-Tabelle leeren für den nächsten Durchlauf
            table.clear(perfBackup)
        end
    end
})














