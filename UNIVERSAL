    Default = false,
    Callback = function(Value)
        if Value then
            -- Setzt die künstliche Verzögerung auf 999 Sekunden (Maximaler Lag)
            settings().Network.IncomingReplicationLag = 999
            
            Fluent:Notify({
                Title = "Network Sabotage",
                Content = "Lag Switch AKTIV. Der Server sieht dich stillstehen!",
                Duration = 3
            })
        else
            -- Zurück auf den Normalzustand (0 Sekunden künstlicher Lag)
            settings().Network.IncomingReplicationLag = 0
            
            Fluent:Notify({
                Title = "Network Sabotage",
                Content = "Lag Switch DEAKTIVIERT. Daten werden synchronisiert.",
                Duration = 3
            })
        end
    end
})

