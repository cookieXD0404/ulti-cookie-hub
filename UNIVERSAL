local hitboxExpansionEnabled = false
local expandedHitboxSize = 2 -- Der Wert vom Slider
local originalSizes = {} -- Speichert die Standardgrößen der Spieler-Parts

local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")

local function monitorHitbox(targetPlayer)
    if targetPlayer == player then return end

    local function setupCharacter(char)
        local root = char:WaitForChild("HumanoidRootPart", 5)
        if not root then return end

        -- Sichert die Originalgröße, falls noch nicht bekannt
        if not originalSizes[targetPlayer.Name] then
            originalSizes[targetPlayer.Name] = root.Size
        end

        -- Kontinuierliche Überprüfung des Parts
        local connection
        connection = runService.RenderStepped:Connect(function()
            if not char or not char.Parent or not root or not root.Parent then
                connection:Disconnect()
                return
            end

            if hitboxExpansionEnabled then
                -- Part vergrößern
                root.Size = Vector3.new(expandedHitboxSize, expandedHitboxSize, expandedHitboxSize)
                root.CanCollide = false -- Verhindert, dass man an den riesigen Hitboxen hängen bleibt
            else
                -- Wieder in den Originalzustand zurückversetzen
                if originalSizes[targetPlayer.Name] then
                    root.Size = originalSizes[targetPlayer.Name]
                    root.CanCollide = true
                end
            end
        end)
    end

    if targetPlayer.Character then
        task.spawn(setupCharacter, targetPlayer.Character)
    end
    targetPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        setupCharacter(char)
    end)
end

-- Registrierung für alle Spieler auf dem Server
for _, p in pairs(game.Players:GetPlayers()) do
    monitorHitbox(p)
end

