local defaultSpeed = 16
local velocityMode = false

local player = game.Players.LocalPlayer
local uis = game:GetService("UserInputService")

-- Funktion zur Prüfung, ob Tasten gedrückt werden
local function isMoving()
    return uis:IsKeyDown(Enum.KeyCode.W) or uis:IsKeyDown(Enum.KeyCode.A) or 
           uis:IsKeyDown(Enum.KeyCode.S) or uis:IsKeyDown(Enum.KeyCode.D)
end

-- Hintergrund-Schleife für Speed-Spam und Velocity-Stopp
task.spawn(function()
    while true do
        task.wait()
        local character = player.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        
        if humanoid and rootPart then
            -- Speed-Spam
            if speedEnabled then
                if humanoid.WalkSpeed ~= targetSpeed and humanoid.WalkSpeed ~= defaultSpeed then
                    defaultSpeed = humanoid.WalkSpeed -- Sichert den Originalwert des Spiels
                end
                humanoid.WalkSpeed = targetSpeed
            end
            
            -- Velocity Mode (Sofort-Stopp)
            if velocityMode and not isMoving() then
                rootPart.AssemblyLinearVelocity = Vector3.new(0, rootPart.AssemblyLinearVelocity.Y, 0)
            end
        end
    end
end)

