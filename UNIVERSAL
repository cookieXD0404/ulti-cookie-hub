local jumpEnabled = false
local targetJump = 50
local defaultJump = 50
local defaultUseJumpPower = true
local jumpMode = "JumpPower" -- Standard-Modus

local player = game.Players.LocalPlayer

-- Hintergrund-Schleife für Jump-Spam
task.spawn(function()
    while true do
        task.wait()
        local character = player.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        
        if humanoid and jumpEnabled then
            -- Backup der Originalwerte, falls noch nicht gesichert
            if humanoid.JumpPower ~= targetJump and humanoid.JumpHeight ~= targetJump and 
               humanoid.JumpPower ~= defaultJump and humanoid.JumpHeight ~= defaultJump then
                defaultJump = humanoid.UseJumpPower and humanoid.JumpPower or humanoid.JumpHeight
                defaultUseJumpPower = humanoid.UseJumpPower
            end
            
            -- Modi abfragen
            if jumpMode == "JumpPower" then
                humanoid.UseJumpPower = true
                humanoid.JumpPower = targetJump
            elseif jumpMode == "JumpHeight" then
                humanoid.UseJumpPower = false
                humanoid.JumpHeight = targetJump
            elseif jumpMode == "Hoch TPn" and rootPart then
                -- Erkennt, wenn der Spieler springt und teleportiert ihn hoch
                local uis = game:GetService("UserInputService")
                if uis:IsKeyDown(Enum.KeyCode.Space) and humanoid.FloorMaterial ~= Enum.Material.Air then
                    rootPart.CFrame = rootPart.CFrame * CFrame.new(0, targetJump / 5, 0)
                    task.wait(0.2) -- Schutz vor unendlichem Hochfliegen
                end
            end
        end
    end
end)

