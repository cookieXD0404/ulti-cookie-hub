-- Unabhängiger Spam-Loop
task.spawn(function()
    local textChatService = game:GetService("TextChatService")
    local players = game:GetService("Players")
    
    while true do
        task.wait(0.1)
        if Fluent.Options.SpamToggle and Fluent.Options.SpamToggle.Value then
            local msg = Fluent.Options.SpamText and Fluent.Options.SpamText.Value or ""
            local delayTime = Fluent.Options.SpamDelay and Fluent.Options.SpamDelay.Value or 2
            
            if msg ~= "" then
                -- Unterstützt das neue Roblox TextChatService System
                if textChatService.ChatVersion == Enum.ChatVersion.TextChatService then
                    local channel = textChatService:FindFirstChild("TextChannels") and textChatService.TextChannels:FindFirstChild("RBXGeneral")
                    if channel then
                        channel:SendAsync(msg)
                    end
                else
                    -- Fallback für das alte Legacy-Chat-System
                    local remote = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
                        and game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents:FindFirstChild("SayMessageRequest")
                    if remote then
                        remote:FireServer(msg, "All")
                    end
                end
            end
            task.wait(delayTime - 0.1) -- Zieht den ersten kurzen Check ab für exakte Raten
        end
    end
end)













