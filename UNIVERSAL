local function isSilentEnemy(targetPlayer)
    if not silentTeamCheck then return true end
    return targetPlayer.Team ~= player.Team
end

local function isSilentVisible(targetPart)
    if not silentWallCheck then return true end
    local castRay = Ray.new(camera.CFrame.Position, (targetPart.Position - camera.CFrame.Position).Unit * 1000)
    local hit = workspace:FindPartOnRayWithIgnoreList(castRay, {player.Character, targetPart.Parent})
