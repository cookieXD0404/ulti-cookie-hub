local espScreenGui = Instance.new("ScreenGui")
espScreenGui.Name = "CookieESP_Screen"
espScreenGui.ResetOnSpawn = false
espScreenGui.Parent = pGui

local function createESPForPlayer(targetPlayer)
    if targetPlayer == player then return end

    local function setupCharacter(char)
        local root = char:WaitForChild("HumanoidRootPart", 5)
        local hum = char:WaitForChild("Humanoid", 5)
        if not root or not hum then return end

        local bGui = char:FindFirstChild("ESPElements") or Instance.new("BillboardGui")
        bGui.Name = "ESPElements"
        bGui.Size = UDim2.new(0, 200, 0, 100)
        bGui.AlwaysOnTop = true
        bGui.StudsOffset = Vector3.new(0, 3.5, 0)
        bGui.Adornee = root
        bGui.Parent = root

        local infoLabel = bGui:FindFirstChild("Info") or Instance.new("TextLabel")
        infoLabel.Name = "Info"
        infoLabel.Size = UDim2.new(1, 0, 1, 0)
        infoLabel.BackgroundTransparency = 1
        infoLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        infoLabel.TextSize = 13
        infoLabel.Font = Enum.Font.SourceSansBold
        infoLabel.TextStrokeTransparency = 0
        infoLabel.Parent = bGui

        local highlight = char:FindFirstChild("ESPHighlight") or Instance.new("Highlight")
        highlight.Name = "ESPHighlight"
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.Adornee = char
        highlight.Parent = char

        local boxFrame = espScreenGui:FindFirstChild("Box_" .. targetPlayer.Name) or Instance.new("Frame")
        if not espScreenGui:FindFirstChild("Box_" .. targetPlayer.Name) then
            boxFrame.Name = "Box_" .. targetPlayer.Name
            boxFrame.BackgroundTransparency = 1
            boxFrame.Parent = espScreenGui
            local stroke = Instance.new("UIStroke")
            stroke.Thickness = 2
            stroke.Parent = boxFrame
        end

        local healthBar = boxFrame:FindFirstChild("HealthBar") or Instance.new("Frame")
        if not boxFrame:FindFirstChild("HealthBar") then
            healthBar.Name = "HealthBar"
            healthBar.BorderSizePixel = 0
            healthBar.Parent = boxFrame
        end

        local tracerLine = espScreenGui:FindFirstChild("Tracer_" .. targetPlayer.Name) or Instance.new("Frame")
        if not espScreenGui:FindFirstChild("Tracer_" .. targetPlayer.Name) then
            tracerLine.Name = "Tracer_" .. targetPlayer.Name
            tracerLine.BorderSizePixel = 0
            tracerLine.AnchorPoint = Vector2.new(0.5, 0.5)
            tracerLine.Parent = espScreenGui
        end

        local connection
        connection = runService.RenderStepped:Connect(function()
            if not targetPlayer or not targetPlayer.Parent or not char or not char.Parent or hum.Health <= 0 then
                boxFrame.Visible = false
                tracerLine.Visible = false
                highlight.Enabled = false
                bGui.Enabled = false
                connection:Disconnect()
                return
            end

            if not espMainEnabled then
                boxFrame.Visible = false
                tracerLine.Visible = false
                highlight.Enabled = false
                bGui.Enabled = false
                return
            end

            local isTeamMate = (targetPlayer.Team == player.Team and game.Teams:FindFirstChild(tostring(player.Team)) ~= nil)
            if espTeamCheck and isTeamMate then
                boxFrame.Visible = false
                tracerLine.Visible = false
                highlight.Enabled = false
                bGui.Enabled = false
                return
            end

            local currentESPColor = Color3.fromRGB(255, 0, 75)
            if targetPlayer.Team and not espTeamCheck then
                currentESPColor = targetPlayer.TeamColor.Color
            end

            highlight.Enabled = espHighlightEnabled
            highlight.FillColor = currentESPColor

            -- ERMITTLUNG DES AKTUELLEN INSET-OFFSETS (Verhindert das Rutschen nach unten)
            local topBarOffset = guiService:GetGuiInset().Y

            local rootPos3D, onScreen = camera:WorldToViewportPoint(root.Position)

            if onScreen then
                -- Korrigierte 2D-Position des Zentrums
                local rootPos = Vector2.new(rootPos3D.X, rootPos3D.Y - topBarOffset)

                local textStr = ""
                if espNamesEnabled then textStr = textStr .. targetPlayer.Name .. "\n" end
                if espHealthEnabled then textStr = textStr .. math.floor(hum.Health) .. " HP" end
                infoLabel.Text = textStr
                bGui.Enabled = (textStr ~= "")

                if espBoxesEnabled then
                    -- Höhenberechnung unter Einbeziehung des Offsets
                    local top3D = camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0))
                    local bottom3D = camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.5, 0))
                    
                    local topY = top3D.Y - topBarOffset
                    local bottomY = bottom3D.Y - topBarOffset
                    
                    local height = math.abs(topY - bottomY)
                    local width = height / 1.4

                    boxFrame.Size = UDim2.new(0, width, 0, height)
                    boxFrame.Position = UDim2.new(0, rootPos.X - width / 2, 0, topY)
                    
                    if boxFrame:FindFirstChildOfClass("UIStroke") then
                        boxFrame:FindFirstChildOfClass("UIStroke").Color = currentESPColor
                    end
                    boxFrame.Visible = true

                    local healthPercent = hum.Health / hum.MaxHealth
                    healthBar.Size = UDim2.new(0, 3, healthPercent, 0)
                    healthBar.Position = UDim2.new(0, -6, 1 - healthPercent, 0)
                    healthBar.BackgroundColor3 = Color3.fromHSV(healthPercent * 0.3, 1, 1)
                    healthBar.Visible = true
                else
                    boxFrame.Visible = false
                end

                if espTracersEnabled then
                    -- Tracer startet unten in der Mitte des korrigierten Viewports
                    local startPos = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y - topBarOffset)
                    local endPos = rootPos
                    local distance = (endPos - startPos).Magnitude

                    tracerLine.Size = UDim2.new(0, distance, 0, 1)
                    tracerLine.Position = UDim2.new(0, (startPos.X + endPos.X) / 2, 0, (startPos.Y + endPos.Y) / 2)
                    tracerLine.Rotation = math.deg(math.atan2(endPos.Y - startPos.Y, endPos.X - startPos.X))
                    tracerLine.BackgroundColor3 = currentESPColor
                    tracerLine.Visible = true
                else
                    tracerLine.Visible = false
                end
            else
                boxFrame.Visible = false
                tracerLine.Visible = false
                bGui.Enabled = false
            end
        end)
    end

    if targetPlayer.Character then
        task.spawn(setupCharacter, targetPlayer.Character)
    end
    targetPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        setupCharacter(char)
    end)
end

